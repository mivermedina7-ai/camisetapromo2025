rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isFounder() {
      return request.auth != null
        && request.auth.token.email in [
          'mivermedina7@gmail.com',
          'williamir1234@gmail.com'
        ];
    }

    function isListedAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.token.email));
    }

    function isAdmin() {
      return isFounder() || isListedAdmin();
    }

    match /recuerdos/{allPaths=**} {
      allow read: if true;
      allow create: if request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow update, delete: if isAdmin();
    }

    match /disenos/{allPaths=**} {
      allow read: if true;
      allow create: if request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow update, delete: if isAdmin();
    }
  }
}